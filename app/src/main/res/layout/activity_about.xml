<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <!-- App icon placeholder -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_launcher_foreground"
            android:background="@drawable/ic_launcher_background"
            android:padding="8dp" />

        <!-- App name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="GPS Mocker"
            android:textColor="@color/accent"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="monospace"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="v1.1.0"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"/>

        <!-- Divider -->
        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:layout_marginVertical="24dp"
            android:background="@color/accent"/>

        <!-- Developer card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👨‍💻  開發者"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="minicore"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="minicore@Claude.ai"
                    android:textColor="@color/accent"
                    android:textSize="14sp"
                    android:fontFamily="monospace"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#2A3050"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦  功能特色"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="• 模式一：固定 GPS 座標注入\n• 模式二：多航點路線模擬\n• 速度可調（0.5 ~ 20 m/s）\n• 循環路線支援\n• Google Fit 步數同步\n• OSMDroid 離線地圖\n• 前景服務持續運作"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.6"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#2A3050"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙️  技術棧"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Kotlin  ·  Android API 29+\nOSMDroid 6.1.18\nGoogle Fit API\nCoroutines  ·  ViewBinding"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.6"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Contact button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContactDev"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="✉️  聯絡開發者"
            android:backgroundTint="@color/accent"
            android:textColor="@color/bg_dark"
            android:textStyle="bold"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="← 返回"
            android:strokeColor="@color/text_secondary"
            android:textColor="@color/text_secondary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Built with ❤️ and Claude AI"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"/>

    </LinearLayout>
</ScrollView>
