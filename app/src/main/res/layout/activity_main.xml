<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ══ Top bar ══ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/dot_grey"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="待機"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginStart="6dp"/>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <TextView
            android:text="GPS Mocker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="monospace"/>

        <!-- About button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAbout"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:text="ℹ️"
            android:textSize="16sp"
            android:minWidth="0dp"
            android:paddingHorizontal="8dp"/>
    </LinearLayout>

    <!-- ══ Google Fit steps row ══ -->
    <LinearLayout
        android:id="@+id/fitRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#12FFFFFF"
        android:paddingHorizontal="12dp"
        android:paddingVertical="5dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvFitSteps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="👟 今日步數：讀取中…"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:fontFamily="monospace"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRefreshFit"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="🔄"
            android:textSize="14sp"
            android:minWidth="0dp"
            android:paddingHorizontal="6dp"/>
    </LinearLayout>

    <!-- ══ Mode toggle ══ -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="6dp"
        app:singleSelection="true"
        app:layout_constraintTop_toBottomOf="@id/fitRow"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModeFixed"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📍 固定點"
            android:textSize="13sp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModeRoute"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🗺️ 多航點路線"
            android:textSize="13sp"/>
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- ══ Mode hint ══ -->
    <TextView
        android:id="@+id/tvModeHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="模式一：固定座標"
        android:textColor="@color/accent"
        android:textSize="11sp"
        android:gravity="center"
        android:paddingVertical="2dp"
        app:layout_constraintTop_toBottomOf="@id/toggleMode"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- ══ Speed row ══ -->
    <LinearLayout
        android:id="@+id/speedRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:background="@color/surface"
        app:layout_constraintTop_toBottomOf="@id/tvModeHint"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ 1.5 m/s 🚶 步行"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:minWidth="130dp"/>

        <SeekBar
            android:id="@+id/seekSpeed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:progress="13"
            android:max="100"
            android:thumbTint="@color/accent"
            android:progressTint="@color/accent"/>
    </LinearLayout>

    <!-- ══ Map ══ -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/speedRow"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ══ Bottom panel ══ -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:elevation="8dp"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvCoords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="點選地圖設定固定位置"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:minLines="2"
            android:paddingBottom="6dp"/>

        <!-- Route-only controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUndoWp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="↩ 刪除最後航點"
                android:textSize="11sp"
                android:enabled="false"/>

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/btnLoopRoute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔁 循環"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:enabled="false"
                android:buttonTint="@color/accent"/>
        </LinearLayout>

        <!-- Main action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:text="▶ 開始"
                android:backgroundTint="@color/accent"
                android:textColor="@color/bg_dark"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStop"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="5dp"
                android:text="⏹ 停止"
                android:enabled="false"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClear"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:text="🗑 清除"
                android:strokeColor="@color/error"
                android:textColor="@color/error"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
